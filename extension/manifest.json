{
  "manifest_version": 3,
  "name": "StudyOS Focus Blocker",
  "version": "1.0",
  "description": "Blocks distracting websites when StudyOS Focus Mode is active.",
  "permissions": ["storage", "alarms"],
  "host_permissions": ["*://localhost/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "StudyOS Blocker"
  }
}
